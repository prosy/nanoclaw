# NanoClaw configuration
# Copy to .env and customize for your environment.

# --- Required for WS bridge (M2-P3) ---

# Shared secret for WS authentication (must match Vercel env)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# WS_AUTH_SECRET=

# --- General ---

# Bot display name (default: Andy)
# ASSISTANT_NAME="Andy"

# Headless mode: start without messaging channels (web-only agent testing)
# When true, NanoClaw runs IPC watcher + scheduler only — no WhatsApp/Telegram/etc.
# NANOCLAW_HEADLESS="true"

# Path to travel-aw-skills checkout (skills/ subdirectory)
# Required for skill execution via IPC
# SKILLS_DIR="/path/to/travel-aw-skills/skills"

# Redis URL for session memory (REQ-6.8.1)
# REDIS_URL="redis://localhost:6379"

# Session TTL in seconds (default: 7200, range: 3600-10800)
# SESSION_TTL_SECONDS="7200"

# --- WebSocket bridge ---

# WS server port (default: 9347)
# WS_PORT=9347

# WS bind address (default: 127.0.0.1)
# WS_BIND=127.0.0.1

# Confirmation timeout in ms (TRAVEL-003, default 5 minutes)
# WS_CONFIRMATION_TIMEOUT_MS=300000

# --- Docker Compose ---

# PostgreSQL password (default: nanoclaw)
# PG_PASSWORD=nanoclaw

# Ollama host URL (default: http://host.docker.internal:11434)
# OLLAMA_HOST=http://host.docker.internal:11434

# Mem0 embedder provider (must be 'ollama' for local embeddings)
# EMBEDDER_PROVIDER=ollama

# NanoClaw version tag for docker-compose (default: latest)
# VERSION=latest
